# Copy to .env and adjust as needed. .env is gitignored.

# Logging verbosity for the practice CLI and benchmarks.
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Random seed for reproducible benchmarks and synthetic-data generation.
DSA_SEED=42

# Where the capstone HNSW index is persisted between runs.
# Override if you want to keep the index outside the repo.
DSA_INDEX_PATH=./14-capstone/index_store

# Optional: limit benchmark sizes when running on a slow machine.
DSA_BENCH_MAX_N=100000
